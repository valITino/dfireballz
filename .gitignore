# Investigation output (host-visible findings — content not tracked)
output/findings/*
!output/findings/.gitkeep
output/screenshots/*
!output/screenshots/.gitkeep
output/logs/*
!output/logs/.gitkeep
output/exports/*
!output/exports/.gitkeep
output/timelines/*
!output/timelines/.gitkeep

