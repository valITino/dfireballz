# DFIReballz Environment Configuration
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────
# Auto-generated on first setup (minimum 32 chars)
POSTGRES_PASSWORD=changeme_run_make_setup_to_generate
POSTGRES_USER=dfireballz
POSTGRES_DB=dfireballz

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MCP Host Selection ─────────────────────────────────────────────
# Options: claude-code | claude-desktop | mcphost | open-webui
MCP_HOST=claude-code

# ─── Claude Code Container (--profile claude-code) ─────────────
# Three auth methods — pick ONE or leave both commented for interactive login.
#
#   1) API key (pay-per-use billing)
#      Quick setup:  make setup-api-key
#      Manual:       uncomment and paste your key below.
#      Get a key at: https://console.anthropic.com/settings/keys
#
#   2) OAuth token (uses Pro/Max subscription quota)
#      Generate on host:  claude setup-token
#      Then uncomment CLAUDE_CODE_OAUTH_TOKEN below and paste it.
#
#   3) Interactive login (default — leave both commented)
#      Claude Code will prompt to log in on first launch.
#      Credentials persist in the claude-config Docker volume.
#
# WARNING: Do NOT set either variable to an empty value — that forces
# Claude Code into "API Usage Billing" mode.  Leave commented if unused.
#
# ANTHROPIC_API_KEY=your_key_here
# CLAUDE_CODE_OAUTH_TOKEN=your_token_here

# ─── API Keys (Threat Intelligence) ─────────────────────────────────
# IMPORTANT: Leave commented out if you don't have the key yet.
# Do NOT set to empty (e.g. VIRUSTOTAL_API_KEY=) — that breaks API lookups.
# After adding keys, restart containers: make restart-threat
#
# VirusTotal — https://www.virustotal.com/gui/my-apikey (free: 4 req/min)
# VIRUSTOTAL_API_KEY=your_key_here

# Shodan — https://account.shodan.io/ (free: limited queries)
# SHODAN_API_KEY=your_key_here

# AbuseIPDB — https://www.abuseipdb.com/account/api (free: 1000 req/day)
# ABUSEIPDB_API_KEY=your_key_here

# URLScan.io — https://urlscan.io/user/signup (free: 50 scans/day)
# URLSCAN_API_KEY=your_key_here

# VulnCheck — https://vulncheck.com/ (free tier available)
# VULNCHECK_API_KEY=your_key_here

# ─── Open WebUI + Ollama (Scenario D only) ───────────────────────────
# Secret key for Open WebUI sessions (must be stable across restarts)
WEBUI_SECRET_KEY=changeme_generate_a_random_string

# API key for mcpo proxy authentication
MCPO_API_KEY=changeme_generate_a_random_string

# Docker group ID (run: getent group docker | cut -d: -f3)
DOCKER_GID=999

# ─── GPU Support ─────────────────────────────────────────────────────
# Set to true if NVIDIA GPU + Container Toolkit installed
ENABLE_GPU=false

# ─── Application ─────────────────────────────────────────────────────
# Case number prefix
CASE_PREFIX=DFIR

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Secret key for orchestrator API
SECRET_KEY=changeme_generate_a_random_string
