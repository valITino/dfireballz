# DFIReballz Environment Configuration
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────
# Auto-generated on first setup (minimum 32 chars)
POSTGRES_PASSWORD=changeme_run_make_setup_to_generate
POSTGRES_USER=dfireballz
POSTGRES_DB=dfireballz

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MCP Host Selection ─────────────────────────────────────────────
# Options: claude-code | claude-desktop | mcphost | open-webui
MCP_HOST=claude-code

# ─── Claude Code Container (--profile claude-code) ─────────────
# Required when running Claude Code inside Docker (make claude-code)
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── API Keys (Threat Intelligence) ─────────────────────────────────
# VirusTotal — https://www.virustotal.com/gui/my-apikey (free: 4 req/min)
VIRUSTOTAL_API_KEY=

# Shodan — https://account.shodan.io/ (free: limited queries)
SHODAN_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api (free: 1000 req/day)
ABUSEIPDB_API_KEY=

# URLScan.io — https://urlscan.io/user/signup (free: 50 scans/day)
URLSCAN_API_KEY=

# VulnCheck — https://vulncheck.com/ (free tier available)
VULNCHECK_API_KEY=

# ─── Open WebUI + Ollama (Scenario D only) ───────────────────────────
# Secret key for Open WebUI sessions (must be stable across restarts)
WEBUI_SECRET_KEY=changeme_generate_a_random_string

# API key for mcpo proxy authentication
MCPO_API_KEY=changeme_generate_a_random_string

# Docker group ID (run: getent group docker | cut -d: -f3)
DOCKER_GID=999

# ─── GPU Support ─────────────────────────────────────────────────────
# Set to true if NVIDIA GPU + Container Toolkit installed
ENABLE_GPU=false

# ─── Application ─────────────────────────────────────────────────────
# Case number prefix
CASE_PREFIX=DFIR

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Secret key for orchestrator API
SECRET_KEY=changeme_generate_a_random_string
